# ============================================================
# HMC v2.1 – Konfiguration
# Kopiere diese Datei nach backend/.env und fülle sie aus.
# ============================================================

# --- Jellyfin ---
JELLYFIN_URL=http://192.168.178.X:8096
JELLYFIN_API_KEY=YOUR_API_KEY

# --- Bibliotheken & Audio ---
# Library-IDs (nicht Namen!) aus Jellyfin Admin-UI kopieren
ALLOWED_LIBRARIES=abc123,def456
AUDIO_DEVICE=hw:1,0

# --- MQTT Discovery ---
# IP-Adresse oder Hostname des Mosquitto-Brokers
MQTT_BROKER=192.168.178.XX

# Port (Standard: 1883, mit TLS: 8883)
MQTT_PORT=1883

# Zugangsdaten – leer lassen wenn kein Login nötig
MQTT_USER=
MQTT_PASSWORD=

# Eindeutige ID dieser HMC-Instanz (nur a-z, 0-9, Unterstrich!)
# Jeder Player im Netz MUSS eine andere ID bekommen.
# Beispiele: hmc_wohnzimmer  hmc_kinderzimmer  hmc_kueche
MQTT_DEVICE_ID=hmc_kinderzimmer

# Anzeigename in Home Assistant (Leerzeichen und Umlaute erlaubt)
MQTT_DEVICE_NAME=HMC Kinderzimmer
